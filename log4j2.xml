<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>

        <!-- Console — coloured for local development -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%-5level] %-40c{1.} %msg%n"/>
        </Console>

        <!-- Rolling file — full ISO timestamps for CI archives -->
        <RollingFile name="FileAppender"
                     fileName="target/logs/api-tests.log"
                     filePattern="target/logs/api-tests-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] [%t] %-40c{1.} %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>

    </Appenders>

    <Loggers>
        <!-- Suppress noisy REST Assured internal logs -->
        <Logger name="io.restassured" level="warn" additivity="false">
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Project logger at INFO -->
        <Logger name="com.apitest" level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Root fallback -->
        <Root level="warn">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileAppender"/>
        </Root>
    </Loggers>
</Configuration>
