<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
    testng.xml — Master test suite configuration.
    Run with: mvn test
    Run a group: mvn test -Dgroups=smoke
    Run an env:  mvn test -Denvironment=staging -Dbase.url=https://staging.api.example.com
-->
<suite name="API Testing Framework" verbose="1" parallel="methods" thread-count="4">

    <listeners>
        <listener class-name="com.apitest.listeners.TestListener"/>
    </listeners>

    <!-- ── Full regression suite ──────────────────────────────────────────── -->
    <test name="Authentication Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
                <include name="auth"/>
                <include name="negative"/>
                <include name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="com.apitest.tests.AuthApiTest"/>
        </classes>
    </test>

    <test name="GET API Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
                <include name="negative"/>
                <include name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="com.apitest.tests.GetApiTest"/>
        </classes>
    </test>

    <test name="POST API Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
                <include name="negative"/>
                <include name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="com.apitest.tests.PostApiTest"/>
        </classes>
    </test>

    <test name="PUT and DELETE API Tests">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
                <include name="negative"/>
                <include name="performance"/>
            </run>
        </groups>
        <classes>
            <class name="com.apitest.tests.PutDeleteApiTest"/>
        </classes>
    </test>

</suite>
